# =====================================================================
# am4bot configuration. Copy to deploy/.env and fill in your values.
# `docker compose` auto-loads deploy/.env when run from the deploy/ dir.
# =====================================================================

# Discord bot token (REQUIRED).
# Get one at https://discord.com/developers/applications -> your app -> Bot.
DISCORD_TOKEN=

# Optional: guild (server) ID to scope slash command sync to one server.
# When set, command updates appear within seconds. When empty, commands
# sync globally and can take up to ~1 hour to propagate.
GUILD_ID=

# SQLite DB path inside the container. Default matches the docker volume
# mount; only change this if you're remapping the volume.
DB_PATH=/data/prices.db

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Price source.
#   null    - no polling; data only via /submit
#   am4help - poll api.am4help.com (requires AM4HELP_TOKEN below)
#   mgtools - poll mgtools.cloud's data-predict-v2 endpoint (no auth)
#   mock    - replay static demo data from theheuman/am4-helper.
#             NOT live AM4 prices — use only for demo/development before
#             you have a real token.
PRICE_SOURCE=null

# Poll interval in seconds (only used when PRICE_SOURCE != null).
POLL_INTERVAL=300

# --- mgtools.cloud adapter (only used when PRICE_SOURCE=mgtools) -----
# POSTs {"timezone": MGTOOLS_TIMEZONE} to <BASE_URL><PRICES_PATH> and
# extracts the slot whose 'time' field is prefixed with '-> ' (mgtools'
# own marker for "the current slot"). No API key required — the
# endpoint enforces only Origin/Referer and a browser User-Agent at
# the WAF, so the defaults below mimic the mgtools.cloud SPA.
MGTOOLS_BASE_URL=https://api.mgtools.cloud
MGTOOLS_PRICES_PATH=/v1/data-predict-v2
MGTOOLS_TIMEZONE=UTC
MGTOOLS_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64; rv:150.0) Gecko/20100101 Firefox/150.0
MGTOOLS_ORIGIN=https://mgtools.cloud
MGTOOLS_REFERER=https://mgtools.cloud/

# IANA timezone used to render times inside the /fuel interval forecast
# timeline (e.g. "Europe/London", "America/New_York", "Asia/Kolkata").
# Falls back to MGTOOLS_TIMEZONE if unset, then UTC. Per-user automatic
# timezones (used elsewhere via Discord's <t:UNIX:R> / <t:UNIX:t>) don't
# work inside ANSI code blocks — the timeline is literal text.
DISPLAY_TIMEZONE=UTC

# --- Mock replay adapter (only used when PRICE_SOURCE=mock) ----------
# URL of a JSON file with the {day -> [{time, fuel, co2}, ...]} shape.
# Default points at theheuman/am4-helper's bundled sample dataset.
MOCK_DATA_URL=https://raw.githubusercontent.com/theheuman/am4-helper/main/src/assets/resource-prices.json

# --- AM4Help adapter (only used when PRICE_SOURCE=am4help) -----------

# API key passed as the `x-access-token` request header.
AM4HELP_TOKEN=

# Base URL and endpoint path for the prices request. The public docs
# don't list a current-prices endpoint, so confirm the real path with
# the API owner and edit AM4HELP_PRICES_PATH accordingly.
AM4HELP_BASE_URL=https://api.am4help.com
AM4HELP_PRICES_PATH=/prices

# Dotted JSON paths to the fuel and CO2 numeric values in the response.
# Examples:
#   "fuel"             top-level key
#   "data.fuel.price"  nested object
#   "items.0.value"    list-index supported
AM4HELP_FUEL_FIELD=fuel
AM4HELP_CO2_FIELD=co2

# --- /submit access control ------------------------------------------
# Comma-separated Discord IDs allowed to use /submit.
# If BOTH lists are empty, /submit is restricted to server admins.
SUBMIT_ALLOWED_ROLES=
SUBMIT_ALLOWED_USERS=
